# Neon Auth URL — get from Neon Console → Auth tab
NEXT_PUBLIC_NEON_AUTH_URL=https://ep-xxx.neonauth.REGION.aws.neon.tech/neondb/auth

# Neon Database — get from Neon Console → Connection Details (use pooled connection)
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Express render server (optional, for desktop mode)
NEXT_PUBLIC_API_URL=http://localhost:4321
